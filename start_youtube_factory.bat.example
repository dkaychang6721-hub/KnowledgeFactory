@echo off
:: 1. Switch to the correct working directory (replace with your own project path)
cd /d C:\path\to\your\KnowledgeFactory

:: 2. Activate the virtual environment using an absolute path
call C:\path\to\your\KnowledgeFactory\.venv\Scripts\activate

:: 3. Run Python
python sync_agent.py

:: 4. Error check: only pause the window on failure so you can read the error
if %errorlevel% neq 0 (
    echo.
    echo =======================================
    echo [FAILED] Task failed. Scroll up to see the error.
    echo =======================================
    pause
    exit /b 1
)

echo.
echo =======================================
echo [DONE] Task finished. Closing in 5 seconds...
echo =======================================
timeout /t 5 > nul
