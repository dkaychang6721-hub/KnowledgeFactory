from dotenv import load_dotenv
load_dotenv()  # 安全讀取同資料夾下的 .env 金鑰

import os
import sys
import asyncio
import datetime
import requests
import pyperclip  # 引入剪貼簿套件
from google.antigravity import Agent, LocalAgentConfig
from google.antigravity.types import Audio

# Gemini 速率限制 / 伺服器過載重試設定
MAX_RETRIES = 4
RETRY_BASE_DELAY = 8  # 秒，每次重試延遲會倍增 (8s → 16s → 32s → 64s)


async def chat_with_retry(agent, prompt, **kwargs):
    """呼叫 Gemini 時自動處理速率限制 / 伺服器過載等暫時性錯誤，採用指數退避重試。"""
    last_error = None
    for attempt in range(1, MAX_RETRIES + 1):
        try:
            return await agent.chat(prompt, **kwargs)
        except Exception as e:
            last_error = e
            err_text = str(e).lower()
            # 涵蓋：429 速率限制 / 503 伺服器過載("high demand"、"unavailable") / 暫時性逾時
            is_retryable = any(keyword in err_text for keyword in [
                "429", "rate", "quota",
                "503", "unavailable", "high demand", "overloaded",
                "deadline exceeded", "timeout",
            ])
            if is_retryable and attempt < MAX_RETRIES:
                delay = RETRY_BASE_DELAY * (2 ** (attempt - 1))
                print(f"⚠️ 偵測到暫時性錯誤（第 {attempt} 次嘗試）：{e}")
                print(f"   {delay} 秒後自動重試...")
                await asyncio.sleep(delay)
                continue
            last_error.attempts_made = attempt
            raise last_error

async def main():
    # =========================================================================
    # 🎯 升級：自動從 Windows 剪貼簿讀取你從 F12 撈到並複製的 MP3 直連網址
    # =========================================================================
    podcast_url = pyperclip.paste().strip()

    # 🚨 安全檢查：確保剪貼簿裡的是音訊直連網址（通常包含 mp3, m4a, wav 等或特定的 podcast 串流特徵）
    # 這裡放寬檢查，只要不是常見的網頁 HTML 結構、或包含常見音訊關鍵字即通過
    if "http" not in podcast_url or (".html" in podcast_url and "mp3" not in podcast_url):
        print("\n❌ 【安全中斷】偵測失敗！")
        print(f"👉 當前剪貼簿內容似乎不是實體音訊網址：\n   \"{podcast_url}\"")
        print("💡 請先去網頁按 F12 複製正確的 .mp3/.m4a 連結後，再點擊執行。")
        sys.exit(1)

    print(f"\n🚀 成功抓取剪貼簿網址: {podcast_url}")

    # 1. 智能檔名生成
    try:
        url_filename = podcast_url.split('/')[-1].split('?')[0]
        base_name = os.path.splitext(url_filename)[0]
        base_name = "".join([c for c in base_name if c.isalpha() or c.isdigit() or c in " _-"])[:30]
        if not base_name:
            base_name = f"Podcast_{datetime.datetime.now().strftime('%Y%m%d_%H%M%S')}"
    except:
        base_name = f"Podcast_{datetime.datetime.now().strftime('%Y%m%d_%H%M%S')}"

    temp_audio_path = f"temp_{base_name}.mp3"

    # 2. 自動確認輸出資料夾（請改成你自己的筆記輸出路徑）
    output_dir = r"C:\path\to\your\Notes\Podcast_Notes"
    os.makedirs(output_dir, exist_ok=True)
    output_path = os.path.join(output_dir, f"{base_name}.md")

    # ─── 階段一：下載音訊檔案 ───
    print(f"\n⏳ 正在從伺服器下載 Podcast 實體音訊檔...")
    try:
        response = requests.get(podcast_url, stream=True)
        if response.status_code == 200:
            with open(temp_audio_path, 'wb') as f:
                for chunk in response.iter_content(chunk_size=8192):
                    f.write(chunk)
            print("💾 音訊下載完成！成功暫存至本地端。")
        else:
            print(f"❌ 下載失敗，伺服器回應代碼：{response.status_code}。網址可能過期或被擋。")
            sys.exit(1)
    except Exception as e:
        print(f"❌ 網路連線或下載發生錯誤：{e}")
        sys.exit(1)

    # ─── 階段二：呼叫 Gemini 進行多模態聽寫與摘要 ───
    print("\n🧠 正在將音訊上傳至 Gemini 進行深度大腦聽寫與結構化排版...")
    print("📢 (提示：語音較長時，Gemini 聽寫可能需要 1~3 分鐘，請耐心等候...)")

    config = LocalAgentConfig(
        system_instructions=(
            "你是一個頂級的知識管理專家。你將收到一段 Podcast 的原始音訊檔案。"
            "請仔細聆聽音訊中的談話內容，將其完整理解後，轉化為繁體中文（台灣），並整理成適合人類閱讀的高級筆記。"
            "要求格式：\n"
            "1. 開頭請整理出本集節目的【核心主題】與【主持人/來賓（若有提及）】。\n"
            "2. 使用結構清晰的 Markdown 標題（## 主要觀點, ### 細節延伸）區隔各個討論區塊。\n"
            "3. 使用項目符號列出核心內容，並對關鍵詞進行**粗體**強調。\n"
            "4. 請務必依據音訊內容，大約標註出該話題討論發生的時間節點（例如：[05:23] 討論市場趨勢）。\n"
            "5. 結尾附上一段精簡的 Summary（總結）與 3 個值得深思的 Takeaways（啟發）。\n"
            "6. 重要：請直接在回覆內容中輸出完整的 Markdown 筆記文字即可，"
            "不要呼叫任何工具（包括 create_file / edit_file 等檔案操作工具），"
            "也不要嘗試自行建立或寫入任何檔案，檔案儲存將完全由外部程式處理。"
        )
    )

    try:
        async with Agent(config) as agent:
            prompt = "請幫我仔細聆聽這段音訊，並依照系統指令整理成排版完美的 Obsidian Markdown 筆記。"
            with open(temp_audio_path, "rb") as f:
                audio_attachment = Audio(data=f.read(), mime_type="audio/mpeg")
            ai_response = await chat_with_retry(agent, [prompt, audio_attachment])

            # ─── 階段三：寫入 Obsidian 與雲端 ───
            with open(output_path, "w", encoding="utf-8") as f:
                f.write(await ai_response.text())

            print(f"\n🎉 大功告成！Podcast 筆記已成功寫入：")
            print(f"📍 路徑: {output_path}")

    except Exception as e:
        attempts = getattr(e, "attempts_made", 1)
        print(f"❌ Gemini 處理過程中發生錯誤（已嘗試 {attempts} 次仍失敗）：{e}")
        print("💡 若錯誤訊息包含「high demand」或「503」，代表 Google 伺服器當下過載，純屬暫時性問題，建議幾分鐘後再重新執行一次。")
        sys.exit(1)

    finally:
        # ─── 階段四：環境清理 ───
        if os.path.exists(temp_audio_path):
            os.remove(temp_audio_path)
            print("🧹 本地暫存音訊檔已自動刪除，環境清理完畢。")

if __name__ == "__main__":
    asyncio.run(main())
